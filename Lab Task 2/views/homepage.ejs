    <!-- HOW IT WORKS SECTION -->
    <section class="how-it-works" id="how-it-works">
        <div class="container">
            <h2 class="section-title">How It Works</h2>
            <p class="section-subtitle">Getting started with WorkerFinder is easy. Follow these three simple steps.</p>

            <div class="steps-container">
                <div class="step">
                    <div class="step-img">
                        <img src="https://img.icons8.com/color/96/000000/edit-file.png" alt="Post Job">
                    </div>
                    <div class="step-number">1</div>
                    <h3 class="step-title">Post a Job</h3>
                    <p class="step-desc">Create a job listing by describing your requirements, location, and budget. It only takes a few minutes.</p>
                </div>

                <div class="step-arrow">→</div>

                <div class="step">
                    <div class="step-img">
                        <img src="https://img.icons8.com/color/96/000000/resume.png" alt="Applications">
                    </div>
                    <div class="step-number">2</div>
                    <h3 class="step-title">Get Applications</h3>
                    <p class="step-desc">Receive applications from qualified workers. Review their profiles, ratings, and previous work experience.</p>
                </div>

                <div class="step-arrow">→</div>

                <div class="step">
                    <div class="step-img">
                        <img src="https://img.icons8.com/color/96/000000/handshake.png" alt="Hire">
                    </div>
                    <div class="step-number">3</div>
                    <h3 class="step-title">Hire the Best Worker</h3>
                    <p class="step-desc">Select the best candidate based on their skills and reviews. Start your project with confidence.</p>
                </div>
            </div>
        </div>
    </section>

